{
  "schema": {
    "name": "klorb-config",
    "version": "1.0.0"
  },
  "sessionDefaults": {
    "model": "openai/gpt-5-nano",
    "thinking.enabled": true,
    "thinking.effort": "high",
    "tools.maxCallsPerTurn": 50,
    "tools.maxCallsPerSession": 200,
    "readDirs": {
      "deny": [
        "~/.ssh",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.oci",
        "~/.ibmcloud",
        "~/.kube",
        "~/.terraform.d",
        "~/.gnupg",
        "~/.age",
        "~/.config/sops",
        "~/.docker",
        "~/.config/containers",
        "~/.config/gh",
        "~/.config/glab-cli",
        "~/.config/op",
        "~/.password-store",
        "~/.local/share/keyrings",
        "~/.pki",
        "/etc/ssh",
        "/etc/sudoers.d",
        "/etc/ssl/private"
      ],
      "ask": [],
      "allow": []
    },
    "writeDirs": {
      "deny": [],
      "ask": [],
      "allow": []
    },
    "commandRules": {
      "deny": [],
      "ask": [],
      "allow": []
    },
    "shareEnv": [],
    "setEnv": {}
  },
  "thinking.tokenBudgets": {
    "low": 4096,
    "medium": 16384,
    "high": 32768
  },
  "terminal.input.maxLines": 12,
  "tools.readFile.maxLines": 200,
  "tools.editFile.driftSearchRadius": 20,
  "tools.grep.maxResults": 500,
  "tools.findFile.maxResults": 500,
  "providers.openrouter.baseUrl": "https://openrouter.ai/api/v1",
  "shell.command": "/bin/bash",
  "shell.timeout": null,
  "tools.bash.command": "/bin/bash",
  "tools.bash.timeout": 120.0,
  "tools.bash.spillBytes": 8192,
  "tools.bash.shfmtCommand": "shfmt",
  "compatibility.claudeMarkdown": false,
  "ui.theme": null
}