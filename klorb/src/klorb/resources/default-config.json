{
  "schema": {
    "name": "klorb-config",
    "version": "1.0.0"
  },
  "sessionDefaults": {
    "model": "openai/gpt-5-nano",
    "thinking.enabled": true,
    "thinking.effort": "high",
    "tools.maxCallsPerTurn": 50,
    "tools.maxCallsPerSession": 200,
    "readDirs": {
      "deny": [
        "~/.ssh",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.oci",
        "~/.ibmcloud",
        "~/.kube",
        "~/.terraform.d",
        "~/.gnupg",
        "~/.age",
        "~/.config/sops",
        "~/.docker",
        "~/.config/containers",
        "~/.config/gh",
        "~/.config/glab-cli",
        "~/.config/op",
        "~/.password-store",
        "~/.local/share/keyrings",
        "~/.pki",
        "/etc/ssh",
        "/etc/sudoers.d",
        "/etc/ssl/private"
      ],
      "ask": [],
      "allow": []
    },
    "writeDirs": {
      "deny": [],
      "ask": [],
      "allow": []
    },
    "readFiles": {
      "deny": [
        "~/.git-credentials",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/.pgpass",
        "~/.my.cnf"
      ],
      "ask": [],
      "allow": [
        "/dev/null",
        "/dev/zero",
        "/dev/random",
        "/dev/urandom"
      ]
    },
    "writeFiles": {
      "deny": [],
      "ask": [],
      "allow": [
        "/dev/null",
        "/dev/zero",
        "/dev/random",
        "/dev/urandom"
      ]
    },
    "skillRules": {
      "deny": [],
      "ask": [],
      "allow": [
        "internal/create-edit-skill"
      ]
    },
    "commandRules": {
      "deny": [
        ["rm", "-rf", "/"]
      ],
      "ask": [],
      "allow": [
        ["true", "**"],
        ["false", "**"],
        ["cat", "*"],
        ["less", "*"],
        ["more", "*"],
        ["head", "?"],
        ["head", "-n", "*", "?"],
        ["tail", "?"],
        ["tail", "-n", "*", "?"],
        ["echo", "**"],
        ["pwd"],
        ["jobs"],
        ["sort"],
        ["sort", "-n"],
        ["uniq"],
        ["uniq", "-c"],
        ["wc", "**"],
        ["jq", "**"],
        ["ls", "**"],
        ["cd", "*"],
        ["pushd", "*"],
        ["popd"]
      ]
    },
    "shareEnv": [
      "LANG", "LC_ALL", "LOCALE", "HOSTTYPE", "MACHTYPE", "TZ"
    ],
    "setEnv": {
      "EDITOR": "false"
    }
  },
  "thinking.tokenBudgets": {
    "low": 4096,
    "medium": 16384,
    "high": 32768
  },
  "terminal.input.maxLines": 12,
  "tools.bash.command": "/bin/bash",
  "tools.bash.timeout": 120.0,
  "tools.bash.spillBytes": 8192,
  "tools.bash.shfmtCommand": "shfmt",
  "tools.bash.riskClassifier.enabled": true,
  "tools.bash.riskClassifier.model": null,
  "tools.bash.riskClassifier.timeout": 5.0,
  "tools.bash.riskClassifier.e2eTimeout": 10.0,
  "tools.bash.riskClassifier.tooRiskyThreshold": 9,
  "tools.bash.riskClassifier.historySize": 20,
  "classifier.model": null,
  "classifier.timeout": 5.0,
  "classifier.e2eTimeout": 10.0,
  "tools.editFile.driftSearchRadius": 20,
  "tools.findFile.maxResults": 100,
  "tools.grep.maxResults": 100,
  "tools.grep.contextLines": 2,
  "tools.logCalls": null,
  "tools.readFile.maxLines": 200,
  "tools.scratchpad.contextLines": 2,
  "providers.openrouter.baseUrl": "https://openrouter.ai/api/v1",
  "shell.command": "/bin/bash",
  "shell.timeout": null,
  "watchdog.timeout": 10.0,
  "compatibility.claudeMarkdown": false,
  "compatibility.claudeSkills": false,
  "ui.theme": null
}
