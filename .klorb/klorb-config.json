{
  "schema": {
    "name": "klorb-config",
    "version": "1.0.0"
  },
  "sessionDefaults": {
    "readDirs": {
      "deny": [],
      "ask": [],
      "allow": [
        "/home/aaron/src/klorb",
        "/home/dev/workspace/klorb"
      ]
    },
    "writeDirs": {
      "deny": [],
      "ask": [],
      "allow": [
        "/home/aaron/src/klorb",
        "/home/dev/workspace/klorb"
      ]
    },
    "commandRules": {
      "deny": [],
      "ask": [],
      "allow": [
        ["grep", "-i", "*"],
        ["make", "**"],
        ["bin/klorb", "--help"],
        ["venv/bin/python", "-m", "pytest", "**"],
        ["./venv/bin/python", "-m", "pytest", "**"],
        ["venv/bin/pytest", "**"],
        ["./venv/bin/pytest", "**"],
        ["venv/bin/python3", "-m", "pytest", "**"],
        ["./venv/bin/python3", "-m", "pytest", "**"],
        ["sed", "-n", "*", "*"],
        ["grep", "-n", "*", "*"],
        ["venv/bin/isort", "**"],
        ["git", "stash"],
        ["git", "stash", "pop"],
        ["git", "log", "--oneline", "?"],
        ["git", "diff", "**"],
        ["git", "status", "--short", "**"],
        ["git", "log", "--oneline", "*"],
        ["git", "status"],
        ["source", "venv/bin/activate"],
        ["grep", "-E", "^(FAILED|PASSED|ERROR)"],
        ["find", "tests", "-name", "conftest.py"],
        ["./venv/bin/flake8", "--config", ".flake8", "src/klorb/sandbox.py"],
        ["grep", "-n", "klorb_dir\\|KLORB_DATA\\|KLORB_STATE\\|tiktoken\\|TIKTOKEN\\|local/share\\|local/state", "tests/test_sandbox.py"],
        ["grep", "-rn", "approved_scopes\\|EscalatePrivileges\\|escalate", "/home/aaron/src/klorb/docs/specs/permissions.md", "/home/aaron/src/klorb/docs/specs/projects-and-trust.md"],
        ["grep", "-E", "^(test|lint|mypy|flake|check|all):", "Makefile"],
        ["grep", "-nA2", "^typecheck:\\|^lint:\\|^test:", "Makefile"],
        ["venv/bin/flake8", "--config", ".flake8", "*"],
        ["python3", "--version"],
        ["which", "**"],
        ["head", "*", "*"],
        ["cat"],
        ["pip", "list"],
        ["pip", "show", "*"],
        ["sleep", "*"],
        ["grep", "-A", "*", "*"],
        ["tail", "*", "*"],
        ["markdownlint-cli2", "--config", "*", "*"]
      ]
    },
    "shareEnv": [
      "TIKTOKEN_CACHE_DIR"
    ],
    "skillRules": {
      "deny": [],
      "ask": [],
      "allow": [
        "workspace:implement-plan",
        "workspace:add-python-dependency"
      ]
    },
    "domains": {
      "deny": [],
      "ask": [],
      "allow": [
        "openrouter.ai"
      ]
    }
  },
  "tools.logCalls": true
}
