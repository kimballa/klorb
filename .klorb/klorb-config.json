{
  "schema": {
    "name": "klorb-config",
    "version": "1.0.0"
  },
  "sessionDefaults": {
    "readDirs": {
      "deny": [],
      "ask": [],
      "allow": [
        "/home/aaron/src/klorb",
        "/home/dev/workspace/klorb"
      ]
    },
    "writeDirs": {
      "deny": [],
      "ask": [],
      "allow": [
        "/home/aaron/src/klorb",
        "/home/dev/workspace/klorb"
      ]
    },
    "commandRules": {
      "deny": [],
      "ask": [],
      "allow": [
        ["grep", "-i", "*"],
        ["make", "**"],
        ["bin/klorb", "--help"],
        ["venv/bin/python", "-m", "pytest", "**"],
        ["./venv/bin/python", "-m", "pytest", "**"],
        ["venv/bin/pytest", "**"],
        ["./venv/bin/pytest", "**"],
        ["sed", "-n", "*", "*"],
        ["grep", "-n", "*", "*"],
        ["venv/bin/isort", "**"],
        ["git", "stash"],
        ["git", "stash", "pop"],
        ["git", "log", "--oneline", "?"],
        ["git", "diff", "--stat", "HEAD"],
        ["git", "diff", "HEAD", "--", "**"],
        ["git", "diff", "--stat", "HEAD", "--", "**"],
        ["git", "status", "--short", "**"],
        ["git", "log", "--oneline", "-5"],
        ["source", "venv/bin/activate"],
        ["git", "log", "--oneline", "-15"],
        ["git", "status"],
        ["grep", "-E", "^(FAILED|PASSED|ERROR)"],
        ["find", "tests", "-name", "conftest.py"],
        ["./venv/bin/flake8", "--config", ".flake8", "src/klorb/sandbox.py"],
        ["grep", "-n", "klorb_dir\\|KLORB_DATA\\|KLORB_STATE\\|tiktoken\\|TIKTOKEN\\|local/share\\|local/state", "tests/test_sandbox.py"]
      ]
    },
    "shareEnv": [
      "TIKTOKEN_CACHE_DIR"
    ]
  },
  "tools.logCalls": true
}
