{
  "permissions": {
    "allow": [
      "Bash(pip show *)",
      "Bash(make venv *)",
      "Bash(make sync_deps)",
      "Bash(make install_dev_deps)",
      "Bash(make test *)",
      "Bash(make lint *)",
      "Bash(make typecheck *)",
      "Bash(venv/bin/pip install *)",
      "Bash(venv/bin/klorb --model openai/gpt-4o-mini \"Reply with exactly the word: pong\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}\"/bin/claude-session-start.sh",
            "timeout": 1800,
            "statusMessage": "Running cloud session setup..."
          }
        ]
      }
    ]
  }
}
