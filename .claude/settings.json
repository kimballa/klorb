{
  "permissions": {
    "allow": [
      "Bash(pip show *)",
      "Bash(make *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * status *)",
      "Bash(git -C * show *)",
      "Bash(git -C * log *)",
      "Bash(venv/bin/pip install *)",
      "Bash(venv/bin/klorb --model *)",
      "Bash(venv/bin/python -m pytest *)",
      "Bash(TESTARGS=* make test)",
      "Bash(env)",
      "WebFetch(domain:openrouter.ai)",
      "WebSearch",
      "Read(//home/aaron/.local/state/klorb/session-logs/**)",
      "Bash(ps aux *)",
      "Bash(git stash *)",
      "Bash(git -C /home/aaron/src/klorb status)",
      "Bash(git -C /home/aaron/src/klorb stash list)",
      "Bash(bwrap --version)",
      "Bash(bwrap --ro-bind / / --proc /proc --dev /dev -- true)",
      "Bash(echo *)",
      "Bash(PYTHONPATH=src:tests venv/bin/pytest * -q)",
      "Bash(PYTHONPATH=src:tests venv/bin/pytest * -q -k *)",
      "Bash(venv/bin/isort --diff *)",
      "Read(//tmp/**)",
      "Skill(code-review)",
      "Skill(code-review:*)",
      "Bash(venv/bin/pip show *)",
      "Bash(venv/bin/flake8 --config .flake8 evals/cases.py)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}\"/bin/claude-session-start.sh",
            "timeout": 1800,
            "statusMessage": "Running cloud session setup..."
          }
        ]
      }
    ]
  }
}
