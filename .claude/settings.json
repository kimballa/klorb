{
  "permissions": {
    "allow": [
      "Bash(pip show *)",
      "Bash(make *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * status *)",
      "Bash(git -C * show *)",
      "Bash(git -C * log *)",
      "Bash(venv/bin/pip install *)",
      "Bash(venv/bin/klorb --model openai/gpt-5-nano *)",
      "Bash(venv/bin/python -m pytest *)",
      "Bash(TESTARGS=* make test)",
      "Bash(env)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}\"/bin/claude-session-start.sh",
            "timeout": 1800,
            "statusMessage": "Running cloud session setup..."
          }
        ]
      }
    ]
  }
}
