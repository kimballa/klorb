{
  "schema": {
    "name": "klorb-config",
    "version": "1.0.0"
  },

  "sessionDefaults": {
    "model": "openai/gpt-4o-mini",
    "thinking.enabled": true,
    "thinking.effort": "high",
    "tools.maxCallsPerTurn": 50,
    "tools.maxCallsPerSession": 200,
    "readDirs": {
      "deny": [
        "~/.ssh",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.oci",
        "~/.ibmcloud",
        "~/.kube",
        "~/.terraform.d",
        "~/.gnupg",
        "~/.age",
        "~/.config/sops",
        "~/.docker",
        "~/.config/containers",
        "~/.config/gh",
        "~/.config/glab-cli",
        "~/.config/op",
        "~/.password-store",
        "~/.local/share/keyrings",
        "~/.pki",
        "/etc/ssh",
        "/etc/sudoers.d",
        "/etc/ssl/private"
      ],
      "ask": [],
      "allow": []
    },
    "writeDirs": {
      "deny": [
        "~/.ssh",
        "~/.aws",
        "~/.azure",
        "~/.config/gcloud",
        "~/.oci",
        "~/.ibmcloud",
        "~/.kube",
        "~/.terraform.d",
        "~/.gnupg",
        "~/.age",
        "~/.config/sops",
        "~/.docker",
        "~/.config/containers",
        "~/.config/gh",
        "~/.config/glab-cli",
        "~/.config/op",
        "~/.password-store",
        "~/.local/share/keyrings",
        "~/.pki",
        "/etc/ssh",
        "/etc/sudoers.d",
        "/etc/ssl/private"
      ],
      "ask": [],
      "allow": []
    }
  },

  "thinking.tokenBudgets": {
    "low": 4096,
    "medium": 16384,
    "high": 32768
  },
  "terminal.input.maxLines": 12,
  "tools.readFile.maxLines": 200,
  "providers.openrouter.baseUrl": "https://openrouter.ai/api/v1"
}
